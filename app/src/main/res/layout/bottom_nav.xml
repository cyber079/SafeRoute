<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="@color/white"
    android:elevation="8dp">

    <!-- Home -->
    <LinearLayout android:id="@+id/navHome"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1" android:orientation="vertical"
        android:gravity="center">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_home" android:contentDescription="Home"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Home" android:textSize="10sp"/>
    </LinearLayout>

    <!-- Map -->
    <LinearLayout android:id="@+id/navMap"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1" android:orientation="vertical"
        android:gravity="center">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_map_pin" android:contentDescription="Map"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Map" android:textSize="10sp"/>
    </LinearLayout>

    <!-- Alerts -->
    <LinearLayout android:id="@+id/navAlerts"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1" android:orientation="vertical"
        android:gravity="center">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_bell" android:contentDescription="Alerts"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Alerts" android:textSize="10sp"/>
    </LinearLayout>

    <!-- Help -->
    <LinearLayout android:id="@+id/navHelp"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1" android:orientation="vertical"
        android:gravity="center">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_phone" android:contentDescription="Help"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Help" android:textSize="10sp"/>
    </LinearLayout>

    <!-- Check-in -->
    <LinearLayout android:id="@+id/navCheckin"
        android:layout_width="0dp" android:layout_height="match_parent"
        android:layout_weight="1" android:orientation="vertical"
        android:gravity="center">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_checkin" android:contentDescription="Check-in"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Check-in" android:textSize="10sp"/>
    </LinearLayout>

</LinearLayout>
